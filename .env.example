# Google Earth Engine configuration
# Copy this file to `.env` in the repository root and fill in your values.
# Do NOT commit `.env` to version control.

# Required: Google Cloud project ID registered with Earth Engine
# Where to find it: https://console.cloud.google.com/ or Earth Engine Code Editor
GEE_PROJECT_ID=

# Required: Earth Engine asset path to your 5 km grid FeatureCollection
# Example: projects/your-gcp-project/assets/up_land_degradation_grid
# Each feature must have properties: Grid_ID, District, Area_km2
GEE_GRID_ASSET_ID=

# Optional: Earth Engine asset path for study-area boundary
# If omitted, the pipeline uses the grid geometry as the AOI
GEE_AOI_ASSET_ID=
